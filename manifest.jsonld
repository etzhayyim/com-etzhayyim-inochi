{
  "@context": {
    "@vocab": "https://etzhayyim.com/ns/actor#",
    "id": "@id",
    "type": "@type"
  },
  "id": "actor:inochi",
  "type": "Actor",
  "name": "inochi",
  "glyph": "命",
  "purpose": "Living-world (生命圏) Knowledge Graph mirror — weaves species / ecosystems / biomes + the pressures borne by the living world into the kotoba Datom log; surfaces ecological 取-concentration routed to RESTORATION, never a target-list.",
  "status": "R0-design-only",
  "tier": "B",
  "adr": "2606073000",
  "dependsOnAdr": ["2606011000", "2606011500", "2605081300", "2605301600", "2605302300", "2606066000", "2605312345", "2605215000", "2605241500"],
  "schema": ["00-contracts/schemas/biosphere-ontology.kotoba.edn"],
  "substrate": {
    "state": "kotoba Datom log (ADR-2605312345) — methods/datom_emit.py emits canonical EAVT",
    "largeAssets": "DataLad → IPFS (80-data/biosphere) — NO git-lfs",
    "inference": "Murakumo-only (ADR-2605215000)",
    "runtime": "kotoba pywasm actor (componentize-py) — pure-stdlib methods, no numpy"
  },
  "integrates": ["actor:tsumugi", "actor:danjo", "actor:kanae", "actor:keizu", "actor:ooyake"],
  "lineage": "living-world sibling of the power-mirror lineage (danjo/tsumugi/ooyake/keizu/kanae); same KG-mirror architecture, biosphere scope",
  "cells": [
    {
      "id": "cell:inochi.analyze",
      "method": "methods/analyze.py",
      "input": "data/seed-biosphere-graph.kotoba.edn",
      "output": ["out/restoration-report.md"],
      "pipeline": "load-edn → edge-primary integral (Σ incident inbound :pressures × disclosed IUCN weight) → restoration-priority + cascade-fragility + pressure-concentration, aggregate-first",
      "doc": "edge-primary ecological 取-concentration; restoration map, never a target-list"
    },
    {
      "id": "cell:inochi.datom-emit",
      "method": "methods/datom_emit.py",
      "input": "data/seed-biosphere-graph.kotoba.edn",
      "output": ["out/biosphere-datoms.kotoba.edn"],
      "pipeline": "ground EAVT datoms [e a v tx :add] (durable) + derived readouts flagged :bond/is-transient (computed on read, N1/G2)",
      "doc": "kotoba Datom-log projection — first-class canonical state (ADR-2605312345)"
    },
    {
      "id": "cell:inochi.coverage",
      "method": "methods/coverage_report.py",
      "input": "data/seed-biosphere-graph.kotoba.edn",
      "output": ["out/coverage-report.md"],
      "pipeline": "denominator (IUCN/described/estimated) + realm + biome + kingdom + pressure-kind → gap map",
      "doc": "honest coverage (all-life ~0 by design); names thin/missing buckets per wave (G5)"
    }
  ],
  "gates": {
    "G1": "RESTORATION map, NEVER a target-list — no occurrence coordinates; biome/realm-aggregate only; the 取-holder is the pressure, the bearer is the living world, the routing is restoration",
    "G2": "edge-primary (N1) — 取 lives only on :en/grasping-load; node restoration-priority is the integral computed on read; no :biosphere/score-of-species",
    "G3": "non-adjudicating (N3) — IUCN categories are DISCLOSED facts, never inochi verdicts",
    "G4": "public venue — open-source + on-chain + 1 SBT = 1 vote; never a private/covert registry",
    "G5": "sourcing honesty — every record :authoritative | :representative; no fabricated coverage",
    "G6": "Murakumo-only narration (ADR-2605215000)",
    "G7": "outward-gated — live planet-scale ingest (IUCN/GBIF/IPCC APIs) requires Council + operator DID; R0 = analyzer + schema + seed only",
    "G8": "no git-lfs — large assets via DataLad → IPFS"
  }
}
